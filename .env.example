# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=v2024-03-25
SANITY_AUTH_TOKEN=your_auth_token
SANITY_WRITE_TOKEN=your_write_token

# ISR Revalidation
SANITY_REVALIDATE_SECRET=your_webhook_secret_here

# reCAPTCHA
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_site_key
RECAPTCHA_SECRET_KEY=your_secret_key

# Paystack (if used)
PAYSTACK_PUBLIC_KEY=your_paystack_key
PAYSTACK_SECRET_KEY=your_paystack_secret

# EmailJS (if used)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key

# Events Registration Email Configuration
ADMIN_EMAIL=your-admin-email@thagospel.com

# Email Service Configuration
# Option 1: Resend (Recommended)
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@thagospel.com

# Option 2: SMTP (Alternative)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=your-email@thagospel.com

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://thagospel.com
NEXT_PUBLIC_SITE_NAME=ThaGospel Church
NEXT_PUBLIC_GIVING_URL=https://your-giving-platform.com
NEXT_PUBLIC_STREAM_URL=https://your-stream-platform.com
