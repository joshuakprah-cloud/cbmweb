{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/new-here/layout,_N_T_/new-here/page,_N_T_/new-here"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/new-here/__PAGE__",
    "/new-here",
    "/_index",
    "/_head"
  ]
}